# 完全自動化用の環境変数テンプレート
#
# このファイルに本物のトークンを書かない。
# 実運用では .env やシェル環境変数で設定し、Git管理しない。

# サイト公開後に設定。未設定だとWordPress/記事URL付き実投稿は止まる。
SITE_BASE_URL=https://example.com

# X API
# X Developer Consoleでユーザー投稿権限を持つアクセストークンを取得後に設定。
X_USER_ACCESS_TOKEN=

# Threads API
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# Instagram API
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=
META_GRAPH_VERSION=v24.0

# OpenAI API: 有料AI生成を使う場合のみ
OPENAI_API_KEY=

# Discord通知: ready投稿候補をDiscordへ流す場合
DISCORD_WEBHOOK_URL=

# 公開・計測
SITE_BASE_URL=
GA4_MEASUREMENT_ID=
GSC_VERIFICATION=
