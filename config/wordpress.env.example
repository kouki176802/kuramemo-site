# コピーして .env.wordpress として保存します。本物の値はGitへ入れません。
WP_LOCAL_PORT=8080
WP_DB_NAME=kuramemo
WP_DB_USER=kuramemo
WP_DB_PASSWORD=change-this-local-password
WP_DB_ROOT_PASSWORD=change-this-root-password
WP_DEBUG=0

# 初回セットアップ用
WP_ADMIN_USER=kuramemo_owner
WP_ADMIN_PASSWORD=change-this-admin-password
WP_ADMIN_EMAIL=owner@example.local
WP_SITE_TITLE=くらメモ
